WATCHTOWER_API_KEY=generate_a_secure_random_key_here
WATCHTOWER_API_PORT=3000
WATCHTOWER_UI_PORT=8080
WATCHTOWER_BIND_ADDRESS=0.0.0.0

# Cognitive Engine
# Local LM Studio, Ollama, or Cloud API (OpenAI/Anthropic)
AI_INFERENCE_URL=http://127.0.0.1:1234/v1/chat/completions
AI_MODEL_ID=local-model

# Directories
WATCHTOWER_DATA_DIR=./data
WATCHTOWER_TARGET_DIR=/path/to/monitor
PYTHON_BIN=python3

# ==========================================
# SENSOR MANAGEMENT (Feature Toggles)
# ==========================================
ENABLE_FIM=true
ENABLE_ORACLE=true
ENABLE_NDR=false     # Note: Requires Zeek to be installed (see README)
ENABLE_ARCHIVER=true
ENABLE_OVERSEER=true

AUTO_REMEDIATE=false  # Set to true to allow AI to quarantine without human approval
ENABLE_DECOY=true
